# ============================================
# Cloner Grupo - Backend Configuration
# ============================================

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cloner_grupo

# Telegram API (obtido em my.telegram.org)
TELEGRAM_API_ID=34587540
TELEGRAM_API_HASH=34e845744628dcb26c8ddf0517c5fe2e

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Sessions directory (where .session files are stored)
SESSIONS_DIR=./sessions

# Temp directory (for media download/reupload)
TEMP_DIR=./tmp

# Logs
LOG_DIR=./logs
LOG_RETENTION_DAYS=30

# Worker
WORKER_ENABLED=true
DEFAULT_SEND_INTERVAL_MS=1000
MAX_CONCURRENCY=1
DEFAULT_TIMEOUT_SECONDS=60
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
